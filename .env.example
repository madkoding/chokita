# Chokita — variables de entorno configurables.
# Copia a .env y edita. Valores = defaults de src/config.py.

# --- Ollama (chat + embeddings) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=liquidai/lfm2.5-1.2b-instruct:latest
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_TIMEOUT_SECONDS=60
OLLAMA_KEEP_ALIVE=-1
OLLAMA_FALLBACK_MESSAGE=No pude contactar al modelo local en este momento.

# --- STT (Qwen3-ASR) ---
ASR_MODEL=Qwen/Qwen3-ASR-1.7B-hf
AUDIO_SAMPLE_RATE=16000

# --- TTS (Piper) ---
PIPER_MODEL_PATH=models/es_ES-sharvard-medium.onnx
PIPER_SPEAKER=1
TTS_FALLBACK_STDOUT=1

# --- Web server ---
WEB_HOST=127.0.0.1
WEB_PORT=8080
# CHOKITA_WS_TOKEN=changeme   # descomentar y setear para exigir token en /ws

# --- Memoria + RAG ---
CHOKITA_DB_PATH=~/.local/share/chokita/chokita.db
RAG_TOP_K=6
HISTORY_WINDOW=20
MAX_TOOL_ITERATIONS=5
CHOKITA_WORKDIR=.

# --- Alma (idle) ---
SOUL_IDLE_THRESHOLD_SECONDS=30
SOUL_REFLECT_MIN_SECONDS=300
SOUL_REFLECT_MAX_SECONDS=900
SOUL_REFLECT_MAX_CHARS=600

# --- REM (sueño) + RAPTOR ---
REM_IDLE_THRESHOLD_SECONDS=600
REM_RAPTOR_INTERVAL_SECONDS=1800
RAPTOR_CLUSTER_K=8
RAPTOR_MAX_LEVELS=4
RAPTOR_SUMMARY_MAX_CHARS=400
RAPTOR_SEED=42

# --- Memoria largo plazo + GC ---
MEMORY_EXTRACT_INTERVAL=10
RAG_MAX_CHUNKS=5000
RAG_REFLECTION_RETENTION_DAYS=14
RAG_MEMORY_RETENTION_DAYS=90
WAL_AUTOCHECKPOINT_PAGES=1000

# --- Contexto / compactación ---
CONTEXT_WINDOW_TOKENS=262144
COMPACT_THRESHOLD=0.80

# --- Shutdown ---
SHUTDOWN_JOIN_TIMEOUT_SECONDS=2